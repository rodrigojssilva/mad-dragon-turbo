{{!-- ESTILO --}}
<div class="sheet-section">
    <h3>{{localize "MDT.style"}}</h3>
    <div class="style-option-group">
        {{#each styles}}
        <div class="style-option">
            <div class="style-header">
                <input type="radio" name="system.style" value="{{this.value}}" {{#if (eq this.value
                    ../system.style)}}checked{{/if}} />
                <strong>{{this.label}}</strong>
            </div>
            <p class="style-desc">{{this.description}}</p>
            <span class="style-stats">{{this.stats}}</span>
        </div>
        {{/each}}
    </div>
</div>

{{!-- VIDA E SANIDADE --}}
<div class="resource-row">
    <div class="resource-block">
        <label>{{localize "MDT.health"}}</label>
        <div class="resource-value-row">
            <input class="resource-input" name="system.health.value" type="number" value="{{system.health.value}}"
                min="0" max="{{system.health.max}}" />
            <span class="resource-sep">/</span>
            <span class="resource-max">{{system.health.max}}</span>
        </div>
    </div>

    <div class="resource-block">
        <label>{{localize "MDT.sanity"}}</label>
        <div class="resource-value-row">
            <input class="resource-input" name="system.sanity.value" type="number" value="{{system.sanity.value}}"
                min="0" max="{{system.sanity.max}}" />
            <span class="resource-sep">/</span>
            <span class="resource-max">{{system.sanity.max}}</span>
        </div>
    </div>
</div>

<div class="sheet-columns">

    {{!-- COLUNA ESQUERDA --}}
    <div class="col-left">

        {{!-- HABILIDADES (ESPECIALIDADES) --}}
        <div class="sheet-section">
            <div class="section-header">
                <h3>{{localize "MDT.specialties"}}</h3>
                <a class="add-specialty"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="items-list">
                {{#each specialties}}
                <li class="item-row" data-item-id="{{this.id}}">
                    <div class="item-summary">
                        <span class="item-name item-toggle">
                            <i class="fas fa-chevron-right item-chevron"></i>
                            {{this.name}}
                        </span>
                        <div class="item-controls">
                            <a class="item-to-chat" data-item-id="{{this.id}}" title="{{localize 'MDT.item.toChat'}}">
                                <i class="fas fa-comment"></i>
                            </a>
                            <a class="item-delete" title="{{localize 'MDT.item.delete'}}">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>

                    {{!-- Collapse --}}
                    <div class="item-description hidden">
                        <input class="item-name-input" type="text" disabled value="{{this.name}}"
                            placeholder="{{localize 'MDT.item.namePlaceholder'}}" />
                        <textarea class="item-desc-input" disabled placeholder="{{localize 'MDT.item.descPlaceholder'}}"
                            rows="3">{{this.system.description}}</textarea>

                        <div class="item-edit-toolbar">
                            <button type="button" class="item-edit-btn item-edit-start" title="Editar"
                                aria-label="Editar">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button type="button" class="item-edit-btn item-edit-cancel hidden" title="Cancelar"
                                aria-label="Cancelar">
                                <i class="fas fa-times"></i>
                            </button>
                            <button type="button" class="item-edit-btn item-edit-save hidden" title="Salvar"
                                aria-label="Salvar">
                                <i class="fas fa-floppy-disk"></i>
                            </button>
                        </div>
                    </div>
                </li>
                {{else}}
                <span>{{localize "MDT.specialty.empty"}}</span>
                {{/each}}
            </ul>
        </div>

        {{!-- ITENS / EQUIPAMENTOS --}}
        <div class="sheet-section">
            <div class="section-header">
                <h3>{{localize "MDT.equipments"}}</h3>
                <a class="add-equipment"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="items-list">
                {{#each equipment}}
                <li class="item-row" data-item-id="{{this.id}}">
                    <div class="item-summary">
                        <span class="item-name item-toggle">
                            <i class="fas fa-chevron-right item-chevron"></i>
                            {{this.name}}
                        </span>
                        <div class="item-controls">
                            <a class="item-to-chat" data-item-id="{{this.id}}" title="{{localize 'MDT.item.toChat'}}">
                                <i class="fas fa-comment"></i>
                            </a>
                            <a class="item-delete" title="{{localize 'MDT.item.delete'}}">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>

                    {{!-- Collapse --}}
                    <div class="item-description hidden">
                        <input class="item-name-input" type="text" disabled value="{{this.name}}"
                            placeholder="{{localize 'MDT.item.namePlaceholder'}}" />
                        <textarea class="item-desc-input" disabled placeholder="{{localize 'MDT.item.descPlaceholder'}}"
                            rows="3">{{this.system.description}}</textarea>

                        <div class="item-edit-toolbar">
                            <button type="button" class="item-edit-btn item-edit-start" title="Editar"
                                aria-label="Editar">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button type="button" class="item-edit-btn item-edit-cancel hidden" title="Cancelar"
                                aria-label="Cancelar">
                                <i class="fas fa-times"></i>
                                <button type="button" class="item-edit-btn item-edit-save hidden" title="Salvar"
                                    aria-label="Salvar">
                                    <i class="fas fa-floppy-disk"></i>
                                </button>
                            </button>
                        </div>
                    </div>
                </li>
                {{else}}
                <span>{{localize "MDT.equipment.empty"}}</span>
                {{/each}}
            </ul>
        </div>
    </div>

    {{!-- COLUNA DIREITA --}}
    <div class="col-right">

        {{> mdt/character-spells-list}}
    </div>
</div>