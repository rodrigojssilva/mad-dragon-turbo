{{> mdt/character-style-section}}
{{> mdt/character-vitals-row}}

<div class="sheet-columns">

    {{!-- COLUNA ESQUERDA --}}
    <div class="col-left">

        {{!-- HABILIDADES (ESPECIALIDADES) --}}
        <div class="sheet-section mdt-top-card mdt-list-card">
            <div class="section-header">
                <h3>{{localize "MDT.specialties"}}</h3>
                <a class="add-specialty"><i class="fas fa-plus"></i></a>
            </div>
            <ul class="items-list">
                {{#each specialties}}
                <li class="item-row" data-item-id="{{this.id}}">
                    <div class="item-summary">
                        <span class="item-name item-toggle">
                            <i class="fas fa-chevron-right item-chevron"></i>
                            {{this.name}}
                        </span>
                        <div class="item-controls">
                            <a class="item-to-chat" data-item-id="{{this.id}}" title="{{localize 'MDT.item.toChat'}}">
                                <i class="fas fa-comment"></i>
                            </a>
                            <a class="item-delete" title="{{localize 'MDT.item.delete'}}">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>

                    {{!-- Collapse --}}
                    <div class="item-description hidden">
                        <label>
                            {{localize "MDT.item.nameLabel"}}
                            <input class="item-name-input" type="text" disabled value="{{this.name}}"
                                placeholder="{{localize 'MDT.item.namePlaceholder'}}" />
                        </label>
                        <label>
                            {{localize "MDT.item.descLabel"}}
                            <textarea class="item-desc-input" disabled
                                placeholder="{{localize 'MDT.item.descPlaceholder'}}"
                                rows="3">{{this.system.description}}</textarea>
                        </label>

                        <div class="item-edit-toolbar">
                            <button type="button" class="item-edit-btn item-edit-start" title="Editar"
                                aria-label="Editar">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button type="button" class="item-edit-btn item-edit-cancel hidden" title="Cancelar"
                                aria-label="Cancelar">
                                <i class="fas fa-times"></i>
                            </button>
                            <button type="button" class="item-edit-btn item-edit-save hidden" title="Salvar"
                                aria-label="Salvar">
                                <i class="fas fa-floppy-disk"></i>
                            </button>
                        </div>
                    </div>
                </li>
                {{else}}
                <span>{{localize "MDT.specialty.empty"}}</span>
                {{/each}}
            </ul>
        </div>

        {{> mdt/character-equipment-list}}
    </div>

    {{!-- COLUNA DIREITA --}}
    <div class="col-right">

        {{> mdt/character-spells-list}}
    </div>
</div>
