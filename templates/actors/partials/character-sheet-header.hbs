{{!-- CABEÇALHO --}}
<header class="sheet-header mdt-top-card mdt-header-card">
    <div class="header-left">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
        <div class="header-actions">
            <button type="button" class="roll-test header-icon-btn" title="{{localize 'MDT.roll.titleBtn'}}">
                <i class="fas fa-dice-d6"></i>
            </button>
            <button type="button" class="rest-test header-icon-btn" title="{{localize 'MDT.spell.rest'}}">
                <i class="fas fa-moon"></i>
            </button>
        </div>
    </div>

    <div class="header-right">
        <h1 class="sheet-title">{{sheetTitle}}</h1>
        <div class="header-field">
            <label for="mdt-header-name">{{localize "MDT.name"}}</label>
            <input id="mdt-header-name" name="name" type="text" value="{{actor.name}}" />
        </div>
        <div class="header-field header-field-concept">
            <div class="header-field-concept-top">
                <label for="mdt-header-concept">{{localize "MDT.concept"}}</label>
                <div class="header-edit-toolbar">
                    <button type="button" class="item-edit-btn concept-edit-start" title="{{localize 'MDT.item.edit'}}"
                        aria-label="{{localize 'MDT.item.edit'}}">
                        <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="item-edit-btn concept-edit-cancel hidden" title="Cancelar"
                        aria-label="Cancelar">
                        <i class="fas fa-times"></i>
                    </button>
                    <button type="button" class="item-edit-btn concept-edit-save hidden" title="Salvar"
                        aria-label="Salvar">
                        <i class="fas fa-floppy-disk"></i>
                    </button>
                </div>
            </div>
            <textarea id="mdt-header-concept" class="concept-input" disabled rows="1"
                placeholder="...">{{system.concept}}</textarea>
        </div>
    </div>
</header>