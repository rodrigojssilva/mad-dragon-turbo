{{!-- ITENS / EQUIPAMENTOS --}}
<div class="sheet-section">
    <div class="section-header">
        <h3>{{localize "MDT.equipments"}}</h3>
        <a class="add-equipment"><i class="fas fa-plus"></i></a>
    </div>
    <ul class="items-list">
        {{#each equipment}}
        <li class="item-row" data-item-id="{{this.id}}">
            <div class="item-summary">
                <span class="item-name item-toggle">
                    <i class="fas fa-chevron-right item-chevron"></i>
                    {{this.name}} (x{{this.system.quantity}})
                </span>
                <div class="item-controls">
                    <a class="item-to-chat" data-item-id="{{this.id}}" title="{{localize 'MDT.item.toChat'}}">
                        <i class="fas fa-comment"></i>
                    </a>
                    <a class="item-delete" title="{{localize 'MDT.item.delete'}}">
                        <i class="fas fa-trash"></i>
                    </a>
                </div>
            </div>

            <div class="item-description hidden">
                <label>
                    {{localize "MDT.item.nameLabel"}}
                    <input class="item-name-input" type="text" disabled value="{{this.name}}"
                        placeholder="{{localize 'MDT.item.namePlaceholder'}}" />
                </label>
                <label>
                    {{localize "MDT.item.descLabel"}}
                    <textarea class="item-desc-input" disabled placeholder="{{localize 'MDT.item.descPlaceholder'}}"
                        rows="3">{{this.system.description}}</textarea>
                </label>

                <div class="equipment-fields">
                    <label>
                        {{localize "MDT.equipment.quantityLabel"}}
                        <input class="equipment-qty-input" type="number" min="0" disabled value="{{this.system.quantity}}" />
                    </label>
                </div>

                <div class="item-edit-toolbar">
                    <button type="button" class="item-edit-btn item-edit-start" title="Editar" aria-label="Editar">
                        <i class="fas fa-pen"></i>
                    </button>
                    <button type="button" class="item-edit-btn item-edit-cancel hidden" title="Cancelar" aria-label="Cancelar">
                        <i class="fas fa-times"></i>
                    </button>
                    <button type="button" class="item-edit-btn item-edit-save hidden" title="Salvar" aria-label="Salvar">
                        <i class="fas fa-floppy-disk"></i>
                    </button>
                </div>
            </div>
        </li>
        {{else}}
        <span>{{localize "MDT.equipment.empty"}}</span>
        {{/each}}
    </ul>
</div>
